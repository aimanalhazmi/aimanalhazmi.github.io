---
import Base from '~/layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Base title={project.data.title} description={project.data.description}>
  <article class="max-w-3xl mx-auto px-6 py-24">
    <a href="/projects/" class="text-sm text-[var(--color-muted)] hover:text-white">← All projects</a>
    <h1 class="font-[var(--font-display)] text-4xl md:text-5xl font-semibold mt-6">{project.data.title}</h1>
    <p class="mt-4 text-lg text-[color:var(--color-muted)]">{project.data.description}</p>
    <div class="flex flex-wrap gap-2 mt-5">
      {project.data.tags.map((t) => <span class="tag">{t}</span>)}
    </div>
    <div class="flex flex-wrap gap-3 mt-6">
      {project.data.repo && <a href={project.data.repo} target="_blank" rel="noopener" class="btn btn-primary text-sm">View on GitHub →</a>}
      {project.data.demo && <a href={project.data.demo} target="_blank" rel="noopener" class="btn text-sm">Live demo →</a>}
    </div>
    <div class="prose prose-invert prose-aiman mt-12 max-w-none">
      <Content />
    </div>
  </article>
</Base>
