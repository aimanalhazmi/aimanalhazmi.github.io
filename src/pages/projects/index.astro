---
import Base from '~/layouts/Base.astro';
import Reveal from '~/components/Reveal';
import ProjectFilter from '~/components/ProjectFilter';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((p) => ({
    slug: p.id,
    title: p.data.title,
    description: p.data.description,
    tags: p.data.tags,
  }));
---

<Base title="Projects">
  <section class="max-w-6xl mx-auto px-6 py-24">
    <Reveal client:load>
      <p class="text-xs uppercase tracking-[0.3em] text-[var(--color-muted)] mb-3">Projects</p>
      <h1 class="font-[var(--font-display)] text-4xl md:text-5xl font-semibold">Things I've built.</h1>
    </Reveal>

    <div class="mt-12">
      <ProjectFilter client:load projects={projects} />
    </div>
  </section>
</Base>
